# Telegram bot token from BotFather
TELEGRAM_BOT_TOKEN=

# Optional comma-separated allowlist of Telegram numeric user IDs
TELEGRAM_ALLOWED_USERS=

# Processing defaults
TCE_TRANSCRIBE_VOICE=true
TCE_DESCRIBE_IMAGES=true
TCE_ENABLE_OCR=true
TCE_TRANSCRIPTION_PROVIDER=groq
TCE_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
TCE_TRANSCRIPTION_LANGUAGE=ru
TCE_VISION_PROVIDER=groq
TCE_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
TCE_OCR_PROVIDER=google_cloud_vision
TCE_MEDIA_SIZE_LIMIT_MB=20
TCE_MAX_MEDIA_ITEMS=
TCE_STRICT=false

# API credentials
GROQ_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/google-vision-service-account.json

# Optional bot working directory
TCE_TELEGRAM_WORKDIR=/tmp/tce-telegram-bot
